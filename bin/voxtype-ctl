#!/usr/bin/env bash
# VoxType per Kommandozeile schalten: voxtype-ctl [toggle|start|stop]
set -u
cmd="${1:-toggle}"
running() { systemctl --user is-active --quiet voxtyped; }
case "$cmd" in toggle) if running; then cmd=stop; else cmd=start; fi ;; esac
case "$cmd" in
    start) systemctl --user start voxtyped voxtype-server voxtype-pill ;;
    stop)  systemctl --user stop voxtyped voxtype-server voxtype-ydotoold ;;
    *) echo "usage: voxtype-ctl [toggle|start|stop]" >&2; exit 2 ;;
esac
